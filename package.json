{
  "name": "catclaw",
  "version": "1.0.0",
  "description": "Local AI agent desktop app powered by OpenClaw, Electron, and provider-ready runtime packaging.",
  "main": "./out/main/index.js",
  "scripts": {
    "bootstrap": "node scripts/bootstrap-runtime.mjs",
    "dev": "npm run bootstrap && electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "package": "npm run bootstrap && npm run build && electron-builder",
    "package:mac": "npm run bootstrap && npm run build && node scripts/verify-package-resources.mjs && electron-builder --mac",
    "package:mac:dir": "npm run bootstrap && npm run build && node scripts/verify-package-resources.mjs && electron-builder --mac dir",
    "package:mac:test": "npm run bootstrap && npm run build && node scripts/verify-package-resources.mjs && electron-builder --mac dir && bash scripts/package-mac-test.sh",
    "package:win": "npm run bootstrap && npm run build && node scripts/verify-package-resources.mjs && electron-builder --win"
  },
  "keywords": [
    "ai-agent",
    "desktop-app",
    "electron",
    "llm",
    "local-ai",
    "ollama",
    "openclaw",
    "react",
    "typescript"
  ],
  "author": "CatClaw",
  "license": "MIT",
  "homepage": "https://github.com/openclaw/catclaw",
  "repository": {
    "type": "git",
    "url": "https://github.com/openclaw/catclaw.git"
  },
  "bugs": {
    "url": "https://github.com/openclaw/catclaw/issues"
  },
  "dependencies": {
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "archiver": "^7.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-store": "^11.0.2",
    "json5": "^2.2.3",
    "lucide-react": "^1.7.0",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "recharts": "^3.8.1",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.0.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "ws": "^8.18.0",
    "zod": "^3.24.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@tailwindcss/vite": "^4.0.12",
    "@types/archiver": "^6.0.3",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@types/ws": "^8.5.14",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.12",
    "typescript": "^5.7.3",
    "vite": "^6.2.1",
    "vitest": "^4.1.3"
  },
  "build": {
    "appId": "ai.openclaw.catclaw",
    "productName": "CatClaw",
    "publish": [
      {
        "provider": "github",
        "owner": "openclaw",
        "repo": "catclaw"
      }
    ],
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": ".catclaw-runtime/runtime/${os}",
        "to": "runtime/${os}"
      },
      {
        "from": ".catclaw-runtime/openclaw",
        "to": "openclaw"
      },
      {
        "from": "resources/trayTemplate.png",
        "to": "resources/trayTemplate.png"
      },
      {
        "from": "resources/trayTemplate@2x.png",
        "to": "resources/trayTemplate@2x.png"
      },
      {
        "from": "build/icon.png",
        "to": "build/icon.png"
      },
      {
        "from": "resources/curated-skills",
        "to": "resources/curated-skills"
      }
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "win": {
      "target": "nsis"
    }
  }
}
